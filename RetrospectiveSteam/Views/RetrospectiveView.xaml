                                                    <Binding Path="Position"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=ItemsControl}" Path="ActualHeight"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Right" Value="0"/>
