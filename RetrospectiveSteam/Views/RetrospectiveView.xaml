                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
